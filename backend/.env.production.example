# Database Configuration
# Production PostgreSQL connection
POSTGRES_DB=charbot
POSTGRES_USER=charbot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Use the service name from docker-compose
DATABASE_URL=postgresql+asyncpg://charbot:CHANGE_ME_STRONG_PASSWORD@postgres:5432/charbot

# API Keys
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# JWT Configuration
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Application Settings
DEBUG=False

# CORS Origins
# For mobile app, use "*" or specific origins
CORS_ORIGINS=["*"]
